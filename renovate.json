{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "schedule:weekly"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "groupName": "minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"]
    }
  ],
  "prHourlyLimit": 4,
  "rangeStrategy": "bump"
}
